# Copy this file to ".env" (in this scripts/ folder) and fill in real values.
# .env is gitignored, so your secret never gets committed.

# The "Internal Integration Secret" from https://www.notion.so/my-integrations
# Starts with "ntn_" (or older "secret_").
NOTION_TOKEN=

# The Manifest page's ID (the 32-char hex from its URL, dashes optional).
NOTION_PAGE_ID=
